  "cards": [
    {
      "dot": "rose",
      "title": "Confidentiality is the hard requirement",
      "items": [
        "Entitlements are resolved before retrieval, so the index only ever returns documents the lawyer may see",
        "Ethical walls change daily; the retriever reads the freshly synced ACLs, not a stale copy",
        "A single confidentiality breach is career-ending, so the wall is enforced at retrieval, not in the prompt"
      ]
    },
    {
      "dot": "emerald",
      "title": "Every answer is sourced",
      "items": [
        "The citation guard checks that each claim resolves to a retrieved passage",
        "An unsourced claim is rejected rather than shown, and the system refuses instead of guessing",
        "This is a routed workflow, not an agent: no tool loop, no autonomous actions"
      ]
    }
  ]
