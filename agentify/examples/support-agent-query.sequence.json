  "cards": [
    {
      "dot": "emerald",
      "title": "Grounded happy path",
      "items": [
        "Every user turn passes an input guardrail before any model sees it",
        "Retrieval runs under the caller identity, so entitlements filter results",
        "The output guardrail checks groundedness before the reply reaches the user"
      ]
    },
    {
      "dot": "rose",
      "title": "Autonomy boundary",
      "items": [
        "Reading subscription data and creating a ticket are tier 0 and tier 1 actions",
        "Anything tier 2 or above (billing, refunds) is not wired to the agent at all",
        "Low retrieval confidence routes the turn to human escalation instead of a guess"
      ]
    }
  ]
