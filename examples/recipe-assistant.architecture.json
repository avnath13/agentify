    { "from": "listbuilder", "to": "shoplist" },
    { "from": "normalizerjob", "to": "catalog", "variant": "dashed", "label": "offline build", "fromSide": "right", "toSide": "bottom" },
    { "from": "normalizerjob", "to": "vocab", "variant": "dashed", "fromSide": "top", "toSide": "bottom" },
    { "from": "evalsuite", "to": "allergen", "variant": "dashed", "fromSide": "top", "toSide": "bottom" }
  ]
